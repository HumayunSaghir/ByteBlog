<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    
    <%
        const blog = locals.data;

        // Split body into paragraphs on blank lines
        const paragraphs = (blog.body || '')
            .split(/\n\s*\n/)
            .map(p => p.trim())
            .filter(p => p.length > 0);

        // Enable drop cap for larger articles
        const hasDropcap = (blog.body || '').length >= 200;
    %>

    <title><%= blog.title %> · ByteBlog</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">

    <link rel="apple-touch-icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">

    <style>
        :root {
            --bb-blue: #2F6BFF;
            --bb-blue-dark: #1E54E0;
            --bb-blue-light: #4F86FF;
            --bb-ink: #0F172A;
            --bb-ink-soft: #1F2937;
            --bb-muted: #64748B;
            --bb-line: #E5E7EB;
            --bb-bg: #F4F5F7;
            --bb-card: #FFFFFF;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            background: var(--bb-bg);
            color: var(--bb-ink);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .bb-page {
            max-width: 760px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        .bb-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--bb-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 22px;
            transition: color 0.18s ease;
        }

        .bb-back:hover {
            color: var(--bb-ink);
        }

        .bb-back svg {
            width: 16px;
            height: 16px;
        }

        .bb-title {
            font-size: 40px;
            line-height: 1.12;
            font-weight: 700;
            letter-spacing: -0.025em;
            margin: 0 0 24px 0;
            color: var(--bb-ink);
            word-wrap: break-word;
        }

        .bb-cover {
            width: 100%;
            border-radius: 20px;
            overflow: hidden;
            margin: 0 0 36px 0;
            background: #F8F9FB;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(15, 23, 42, 0.04);
        }

        .bb-cover img {
            display: block;
            width: 100%;
            height: auto;
            max-height: 600px;
            object-fit: contain;
            margin: 0 auto;
        }

        .bb-body {
            font-size: 18px;
            line-height: 1.78;
            color: var(--bb-ink-soft);
            margin: 0 0 44px 0;
            font-weight: 400;
            letter-spacing: -0.003em;
        }

        .bb-body p {
            margin: 0 0 1.4em 0;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        .bb-body.has-dropcap>p:first-child::first-letter {
            float: left;
            font-size: 3.4em;
            line-height: 0.9;
            font-weight: 700;
            color: var(--bb-blue);
            padding: 4px 12px 0 0;
            margin-top: 4px;
            letter-spacing: -0.04em;
        }

        .bb-author-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.06);
            border-radius: 18px;
            padding: 18px 22px;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03), 0 4px 12px rgba(15, 23, 42, 0.04);
            flex-wrap: wrap;
        }

        .bb-author-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .bb-author-img,
        .bb-avatar-fallback {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            background: linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
            display: grid;
            place-items: center;
            color: #fff;
            font-weight: 700;
            font-size: 18px;
            text-transform: uppercase;
        }

        .bb-author-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .bb-author-label {
            font-size: 11.5px;
            color: var(--bb-muted);
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-weight: 500;
        }

        .bb-author-name {
            font-size: 16px;
            font-weight: 600;
            color: var(--bb-ink);
            margin: 0;
        }

        .bb-published {
            font-size: 13px;
            color: var(--bb-muted);
            font-weight: 500;
        }

        .bb-comments {
            margin-top: 48px;
            padding-top: 36px;
            border-top: 1px solid var(--bb-line);
        }

        .bb-comments-title {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .bb-count-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
            height: 24px;
            padding: 0 8px;
            background: rgba(47, 107, 255, 0.10);
            color: var(--bb-blue);
            border-radius: 999px;
            font-size: 12.5px;
            font-weight: 600;
        }

        .bb-comment-form {
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.06);
            border-radius: 18px;
            padding: 18px;
            margin-bottom: 28px;
        }

        .bb-comment-row {
            display: flex;
            gap: 12px;
        }

        .bb-comment-input {
            flex: 1;
            padding: 12px 16px;
            border-radius: 12px;
            border: 1px solid var(--bb-line);
            font-size: 14px;
            outline: none;
        }

        .bb-comment-input:focus {
            border-color: var(--bb-blue);
        }

        .bb-comment-submit {
            padding: 0 18px;
            border: none;
            border-radius: 12px;
            background: var(--bb-blue);
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }

        .bb-comment-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .bb-comment {
            display: flex;
            gap: 14px;
            background: #fff;
            border-radius: 16px;
            padding: 16px 18px;
            border: 1px solid rgba(15, 23, 42, 0.05);
        }

        .bb-comment-img,
        .bb-comment-fallback {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            background: linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
            display: grid;
            place-items: center;
            color: #fff;
            font-weight: 700;
            font-size: 14px;
        }

        .bb-comment-author {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 4px;
        }

        .bb-comment-text {
            margin: 0;
            line-height: 1.6;
            color: var(--bb-ink-soft);
        }

        .bb-empty {
            text-align: center;
            padding: 32px 20px;
            color: var(--bb-muted);
            background: #fff;
            border-radius: 16px;
            border: 1px dashed var(--bb-line);
        }

        @media (max-width: 720px) {
            .bb-page {
                padding: 20px 16px 56px;
            }

            .bb-title {
                font-size: 28px;
            }

            .bb-comment-row {
                flex-direction: column;
            }

            .bb-comment-submit {
                height: 44px;
            }
        }
    </style>
</head>

<body>

    <%- include('./partials/nav') %>

    <div class="bb-page">

        <!-- Back -->
        <a href="/" class="bb-back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all posts
        </a>

        <!-- Title -->
        <h1 class="bb-title"><%= blog.title %></h1>

        <!-- Cover -->
        <% if(blog.coverImageUrl){ %>
            <figure class="bb-cover">
                <img src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>">
            </figure>
        <% } %>

        <!-- Body -->
        <article class="bb-body <%= hasDropcap ? 'has-dropcap' : '' %>">
            <% if(paragraphs.length > 0){ %>

                <% paragraphs.forEach(paragraph => { %>
                    <p><%= paragraph %></p>
                <% }) %>

            <% } else { %>

                <p><%= blog.body %></p>

            <% } %>
        </article>

        <!-- Author -->
        <div class="bb-author-card">

            <div class="bb-author-left">

                <% if(blog.createdBy && blog.createdBy.profileImageUrl){ %>

                    <img class="bb-author-img"
                        src="<%= blog.createdBy.profileImageUrl %>"
                        alt="<%= blog.createdBy.fullname %>">

                <% } else { %>

                    <span class="bb-avatar-fallback">
                        <%= blog.createdBy && blog.createdBy.fullname
                            ? blog.createdBy.fullname.charAt(0)
                            : 'A' %>
                    </span>

                <% } %>

                <div class="bb-author-info">
                    <span class="bb-author-label">Written by</span>
                    <h3 class="bb-author-name"><%= blog.createdBy.fullname %></h3>
                </div>

            </div>

            <div class="bb-published">
                Published On :
                <%= blog.createdAt.toLocaleString() %>
            </div>

        </div>

        <!-- Comments -->
        <section class="bb-comments">

            <h2 class="bb-comments-title">
                Comments
                <span class="bb-count-pill"><%= locals.commentsData.length %></span>
            </h2>

            <% if(locals.user !== undefined){ %>

                <form class="bb-comment-form"
                    action="/blog/addComment/<%= blog._id %>"
                    method="post">

                    <div class="bb-comment-row">

                        <input
                            type="text"
                            name="content"
                            class="bb-comment-input"
                            placeholder="Share your thoughts..."
                            required>

                        <button type="submit" class="bb-comment-submit">
                            Post
                        </button>

                    </div>

                </form>

            <% } %>

            <!-- All comments -->

            <% if(locals.commentsData && locals.commentsData.length > 0){ %>

                <div class="bb-comment-list">

                    <% locals.commentsData.forEach(comment => { %>

                        <div class="bb-comment">

                            <% if(comment.createdBy && comment.createdBy.profileImageUrl){ %>

                                <img class="bb-comment-img"
                                    src="<%= comment.createdBy.profileImageUrl %>"
                                    alt="<%= comment.createdBy.fullname %>">

                            <% } else { %>

                                <span class="bb-comment-fallback">
                                    <%= comment.createdBy.fullname.charAt(0) %>
                                </span>

                            <% } %>

                            <div class="bb-comment-content">

                                <h5 class="bb-comment-author">
                                    <%= comment.createdBy.fullname %>
                                </h5>

                                <p class="bb-comment-text">
                                    <%= comment.content %>
                                </p>

                            </div>

                        </div>

                    <% }) %>

                </div>

            <% } else { %>

                <div class="bb-empty">
                    No comments yet — be the first to comment.
                </div>

            <% } %>

        </section>

    </div>

    <%- include('./partials/script') %>

</body>
</html>