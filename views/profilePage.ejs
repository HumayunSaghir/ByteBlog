<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= locals.name ? locals.name + ' · Profile' : 'Profile' %> · ByteBlog</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">

    <style>
        :root {
            --bb-blue: #2F6BFF;
            --bb-blue-dark: #1E54E0;
            --bb-blue-light: #4F86FF;
            --bb-ink: #0F172A;
            --bb-ink-soft: #1F2937;
            --bb-muted: #64748B;
            --bb-line: #E5E7EB;
            --bb-bg: #F4F5F7;
            --bb-card: #FFFFFF;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            background: var(--bb-bg);
            color: var(--bb-ink);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .bb-page {
            max-width: 1000px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        /* Back link */
        .bb-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--bb-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 24px;
            transition: color 0.18s ease;
        }
        .bb-back:hover { color: var(--bb-ink); }
        .bb-back svg { width: 16px; height: 16px; }

        /* ===== PROFILE HEADER CARD ===== */
        .bb-profile-hero {
            position: relative;
            background:
                radial-gradient(120% 80% at 0% 0%, rgba(255,255,255,0.12), transparent 60%),
                radial-gradient(80% 60% at 100% 100%, rgba(255,255,255,0.08), transparent 55%),
                linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
            border-radius: 24px;
            padding: 40px 44px;
            margin-bottom: 28px;
            overflow: hidden;
            box-shadow: 0 16px 40px rgba(30, 84, 224, 0.20);
        }

        .bb-profile-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.10) 1px, transparent 1px);
            background-size: 24px 24px;
            opacity: 0.4;
            pointer-events: none;
        }

        .bb-profile-hero::after {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
            bottom: -180px;
            right: -140px;
            pointer-events: none;
        }

        .bb-profile-hero-inner {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 28px;
        }

        /* Profile image */
        .bb-profile-img-wrap {
            position: relative;
            flex-shrink: 0;
        }

        .bb-profile-img,
        .bb-profile-fallback {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255, 255, 255, 0.35);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.20);
            display: block;
        }

        .bb-profile-fallback {
            background: rgba(255, 255, 255, 0.20);
            display: grid;
            place-items: center;
            color: #fff;
            font-size: 36px;
            font-weight: 700;
            text-transform: uppercase;
            border: 3px solid rgba(255, 255, 255, 0.35);
        }

        /* Profile info */
        .bb-profile-info {
            flex: 1;
            min-width: 0;
        }

        .bb-profile-eyebrow {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255, 255, 255, 0.72);
            font-weight: 500;
            margin-bottom: 6px;
        }

        .bb-profile-name {
            font-size: 32px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.025em;
            margin: 0 0 6px 0;
            line-height: 1.1;
            word-wrap: break-word;
        }

        .bb-profile-email {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.80);
            font-weight: 400;
            margin-bottom: 20px;
        }

        .bb-profile-email svg { width: 14px; height: 14px; opacity: 0.80; }

        .bb-profile-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .bb-profile-cta {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 10px 18px;
            font-size: 13.5px;
            font-weight: 600;
            border-radius: 10px;
            text-decoration: none;
            transition: background 0.18s ease, transform 0.05s ease;
            cursor: pointer;
            font-family: inherit;
            border: none;
        }

        .bb-profile-cta.primary {
            background: #fff;
            color: var(--bb-blue);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.14);
        }
        .bb-profile-cta.primary:hover { background: #F0F4FF; }
        .bb-profile-cta.primary:active { transform: translateY(1px); }

        .bb-profile-cta.ghost {
            background: rgba(255, 255, 255, 0.12);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
        .bb-profile-cta.ghost:hover { background: rgba(255, 255, 255, 0.20); }
        .bb-profile-cta svg { width: 15px; height: 15px; }

        /* Stats row */
        .bb-stats-row {
            display: flex;
            gap: 24px;
            margin-top: 24px;
            padding-top: 22px;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
        }

        .bb-stat {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .bb-stat-num {
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.02em;
            line-height: 1;
        }

        .bb-stat-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.10em;
            color: rgba(255, 255, 255, 0.70);
            font-weight: 500;
        }

        /* ===== BLOGS SECTION ===== */
        .bb-blogs-section {
            margin-top: 8px;
        }

        .bb-section-head {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 22px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--bb-line);
            gap: 16px;
        }

        .bb-section-left {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .bb-section-eyebrow {
            font-size: 11.5px;
            color: var(--bb-blue);
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .bb-section-eyebrow::before {
            content: "";
            width: 20px;
            height: 1px;
            background: var(--bb-blue);
        }

        .bb-section-title {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--bb-ink);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .bb-count-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
            height: 24px;
            padding: 0 8px;
            background: rgba(47, 107, 255, 0.10);
            color: var(--bb-blue);
            border-radius: 999px;
            font-size: 12.5px;
            font-weight: 600;
        }

        /* Blog list */
        .bb-blog-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .bb-blog-item {
            display: flex;
            align-items: center;
            gap: 18px;
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.05);
            border-radius: 16px;
            padding: 16px 20px;
            text-decoration: none;
            color: inherit;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.03);
        }
        .bb-blog-item:hover {
            transform: translateY(-2px);
            border-color: rgba(15, 23, 42, 0.10);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        }

        .bb-blog-num {
            font-size: 13px;
            font-weight: 700;
            color: rgba(47, 107, 255, 0.35);
            letter-spacing: -0.02em;
            min-width: 28px;
            font-feature-settings: "tnum";
            flex-shrink: 0;
        }

        .bb-blog-cover {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            overflow: hidden;
            flex-shrink: 0;
            background: radial-gradient(circle at 50% 50%, #FAFBFC 0%, #ECEEF1 100%);
            border: 1px solid var(--bb-line);
        }

        .bb-blog-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .bb-blog-cover-fallback {
            width: 100%;
            height: 100%;
            display: grid;
            place-items: center;
            color: var(--bb-muted);
        }
        .bb-blog-cover-fallback svg { width: 22px; height: 22px; opacity: 0.4; }

        .bb-blog-content {
            flex: 1;
            min-width: 0;
        }

        .bb-blog-tag {
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 0.10em;
            text-transform: uppercase;
            color: var(--bb-blue);
            margin-bottom: 5px;
        }

        .bb-blog-title {
            font-size: 15.5px;
            font-weight: 600;
            color: var(--bb-ink);
            letter-spacing: -0.01em;
            line-height: 1.35;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .bb-blog-arrow {
            flex-shrink: 0;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--bb-bg);
            border: 1.5px solid var(--bb-line);
            display: grid;
            place-items: center;
            color: var(--bb-muted);
            transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
        }
        .bb-blog-item:hover .bb-blog-arrow {
            background: var(--bb-blue);
            border-color: var(--bb-blue);
            color: #fff;
            transform: translateX(2px);
        }
        .bb-blog-arrow svg { width: 14px; height: 14px; }

        /* Empty blogs state */
        .bb-empty {
            background: #fff;
            border: 1px dashed var(--bb-line);
            border-radius: 18px;
            padding: 48px 24px;
            text-align: center;
            color: var(--bb-muted);
        }

        .bb-empty-icon {
            width: 52px;
            height: 52px;
            margin: 0 auto 14px;
            border-radius: 14px;
            background: rgba(47, 107, 255, 0.08);
            color: var(--bb-blue);
            display: grid;
            place-items: center;
        }

        .bb-empty h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--bb-ink);
            margin: 0 0 6px 0;
            letter-spacing: -0.015em;
        }

        .bb-empty p {
            font-size: 14px;
            margin: 0 0 20px 0;
            line-height: 1.55;
        }

        .bb-empty-cta {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 11px 20px;
            background: linear-gradient(180deg, #3D77FF 0%, #2F6BFF 100%);
            color: #fff;
            text-decoration: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(47,107,255,0.32), inset 0 1px 0 rgba(255,255,255,0.18);
            transition: box-shadow 0.18s ease, transform 0.05s ease;
        }
        .bb-empty-cta:hover {
            background: linear-gradient(180deg, #2F6BFF 0%, #1E54E0 100%);
            box-shadow: 0 10px 26px rgba(47,107,255,0.38), inset 0 1px 0 rgba(255,255,255,0.18);
        }
        .bb-empty-cta:active { transform: translateY(1px); }
        .bb-empty-cta svg { width: 14px; height: 14px; }

        /* Mobile */
        @media (max-width: 720px) {
            .bb-page { padding: 20px 16px 56px; }
            .bb-profile-hero { padding: 28px 24px; border-radius: 20px; }
            .bb-profile-hero-inner { flex-direction: column; align-items: flex-start; gap: 20px; }
            .bb-profile-img, .bb-profile-fallback { width: 80px; height: 80px; font-size: 28px; }
            .bb-profile-name { font-size: 26px; }
            .bb-stats-row { gap: 20px; flex-wrap: wrap; }
            .bb-stat-num { font-size: 20px; }
            .bb-blog-item { padding: 14px 16px; gap: 14px; }
            .bb-blog-cover { width: 52px; height: 52px; }
            .bb-blog-title { font-size: 14.5px; }
        }
    </style>
</head>
<body>

    <%- include('./partials/nav') %>

    <div class="bb-page">

        <a href="/" class="bb-back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to home
        </a>

        <% if (locals.name && locals.email && locals.profileImageUrl && locals.allBlogs) { %>

            <!-- PROFILE HERO -->
            <div class="bb-profile-hero">
                <div class="bb-profile-hero-inner">

                    <!-- Avatar -->
                    <div class="bb-profile-img-wrap">
                        <% if (locals.profileImageUrl && locals.profileImageUrl !== '/images/default.png') { %>
                            <img class="bb-profile-img" src="<%= locals.profileImageUrl %>" alt="<%= locals.name %>">
                        <% } else { %>
                            <div class="bb-profile-fallback"><%= locals.name.charAt(0) %></div>
                        <% } %>
                    </div>

                    <!-- Info -->
                    <div class="bb-profile-info">
                        <p class="bb-profile-eyebrow">ByteBlog Member</p>
                        <h1 class="bb-profile-name"><%= locals.name %></h1>
                        <div class="bb-profile-email">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <path d="m22 7-10 5L2 7"/>
                            </svg>
                            <%= locals.email %>
                        </div>
                        <div class="bb-profile-actions">
                            <a href="/user/changeProfileImage" class="bb-profile-cta primary">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                                    <circle cx="12" cy="13" r="4"/>
                                </svg>
                                Change Profile Image
                            </a>
                            <a href="/blog/addBlog" class="bb-profile-cta ghost">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 20h9"></path>
                                    <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                                </svg>
                                Write a Post
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="bb-stats-row">
                    <div class="bb-stat">
                        <span class="bb-stat-num"><%= locals.allBlogs.length %></span>
                        <span class="bb-stat-label">Posts</span>
                    </div>
                    <div class="bb-stat">
                        <span class="bb-stat-num">—</span>
                        <span class="bb-stat-label">Followers</span>
                    </div>
                    <div class="bb-stat">
                        <span class="bb-stat-num">—</span>
                        <span class="bb-stat-label">Following</span>
                    </div>
                </div>
            </div>

            <!-- BLOGS SECTION -->
            <div class="bb-blogs-section">

                <div class="bb-section-head">
                    <div class="bb-section-left">
                        <span class="bb-section-eyebrow">Written by <%= locals.name.split(' ')[0] %></span>
                        <h2 class="bb-section-title">
                            Your Blogs
                            <span class="bb-count-pill"><%= locals.allBlogs.length %></span>
                        </h2>
                    </div>
                </div>

                <% if (locals.allBlogs.length > 0) { %>
                    <div class="bb-blog-list">
                        <% locals.allBlogs.forEach((blog, idx) => { %>
                            <a href="/blog/showBlog/<%= blog._id %>" class="bb-blog-item">

                                <span class="bb-blog-num"><%= String(idx + 1).padStart(2, '0') %></span>

                                <div class="bb-blog-cover">
                                    <% if (blog.coverImageUrl) { %>
                                        <img src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>" loading="lazy">
                                    <% } else { %>
                                        <div class="bb-blog-cover-fallback">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                                <polyline points="21 15 16 10 5 21"></polyline>
                                            </svg>
                                        </div>
                                    <% } %>
                                </div>

                                <div class="bb-blog-content">
                                    <div class="bb-blog-tag">Article</div>
                                    <div class="bb-blog-title"><%= blog.title %></div>
                                </div>

                                <div class="bb-blog-arrow">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                        <polyline points="12 5 19 12 12 19"></polyline>
                                    </svg>
                                </div>

                            </a>
                        <% }) %>
                    </div>

                <% } else { %>
                    <div class="bb-empty">
                        <div class="bb-empty-icon">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9"></path>
                                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                            </svg>
                        </div>
                        <h3>No posts yet</h3>
                        <p>You haven't written anything yet.<br>Your first post is just a click away.</p>
                        <a href="/blog/addBlog" class="bb-empty-cta">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9"></path>
                                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                            </svg>
                            Write your first post
                        </a>
                    </div>
                <% } %>

            </div>

        <% } %>

    </div>

    <%- include('./partials/script') %>
</body>
</html>