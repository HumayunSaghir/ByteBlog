<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Write a new post · ByteBlog</title>

    <!-- Favicon (inline SVG — matches the ByteBlog logo mark) -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">

    <style>
        :root {
            --bb-blue: #2F6BFF;
            --bb-blue-dark: #1E54E0;
            --bb-blue-light: #4F86FF;
            --bb-ink: #0F172A;
            --bb-muted: #64748B;
            --bb-line: #E5E7EB;
            --bb-bg: #F4F5F7;
            --bb-card: #FFFFFF;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            background: var(--bb-bg);
            color: var(--bb-ink);
            -webkit-font-smoothing: antialiased;
        }

        /* Page wrapper */
        .bb-page {
            max-width: 880px;
            margin: 0 auto;
            padding: 32px 24px 64px;
        }

        /* Page header — small hero strip */
        .bb-page-head {
            position: relative;
            background:
                radial-gradient(120% 80% at 0% 0%, rgba(255,255,255,0.12), transparent 60%),
                radial-gradient(80% 60% at 100% 100%, rgba(255,255,255,0.08), transparent 55%),
                linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
            color: #fff;
            padding: 36px 40px;
            border-radius: 24px;
            overflow: hidden;
            margin-bottom: 24px;
            box-shadow: 0 16px 40px rgba(30,84,224,0.22);
        }

        .bb-page-head::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.10) 1px, transparent 1px);
            background-size: 22px 22px;
            opacity: 0.4;
            pointer-events: none;
        }

        .bb-page-head::after {
            content: "";
            position: absolute;
            width: 360px;
            height: 360px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
            bottom: -160px;
            right: -120px;
            pointer-events: none;
        }

        .bb-eyebrow {
            position: relative;
            z-index: 1;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(255,255,255,0.14);
            border: 1px solid rgba(255,255,255,0.24);
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        .bb-page-head h1 {
            position: relative;
            z-index: 1;
            font-size: 34px;
            font-weight: 700;
            margin: 14px 0 8px 0;
            letter-spacing: -0.025em;
            line-height: 1.15;
        }

        .bb-page-head p {
            position: relative;
            z-index: 1;
            font-size: 15px;
            line-height: 1.55;
            color: rgba(255,255,255,0.85);
            margin: 0;
            max-width: 560px;
        }

        /* Card */
        .bb-card {
            background: var(--bb-card);
            border-radius: 24px;
            padding: 36px 36px;
            box-shadow:
                0 1px 2px rgba(15,23,42,0.04),
                0 8px 24px rgba(15,23,42,0.06),
                0 24px 60px rgba(15,23,42,0.05);
            border: 1px solid rgba(15,23,42,0.04);
        }

        /* Alert */
        .bb-alert {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 14px 16px;
            background: #FEF2F2;
            border: 1px solid #FECACA;
            color: #991B1B;
            border-radius: 14px;
            font-size: 13.5px;
            margin-bottom: 22px;
        }

        .bb-alert svg { flex-shrink: 0; margin-top: 1px; }
        .bb-alert p { margin: 0; line-height: 1.45; }

        /* Form fields */
        .bb-field { margin-bottom: 22px; }

        .form-label {
            display: block;
            font-size: 13.5px;
            font-weight: 600;
            color: var(--bb-ink);
            margin-bottom: 9px;
            letter-spacing: -0.005em;
        }

        .form-hint {
            font-size: 12.5px;
            font-weight: 400;
            color: var(--bb-muted);
            margin-left: 6px;
        }

        .form-control {
            width: 100%;
            padding: 14px 18px;
            font-size: 15px;
            font-family: inherit;
            color: var(--bb-ink);
            background: #FAFBFC;
            border: 1.5px solid var(--bb-line);
            border-radius: 14px;
            outline: none;
            transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
        }

        .form-control::placeholder { color: #9AA3B2; }
        .form-control:hover { background: #fff; border-color: #D1D5DB; }
        .form-control:focus {
            border-color: var(--bb-blue);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(47,107,255,0.12);
        }

        /* Title — bigger, editorial feel */
        .bb-title-input {
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.015em;
            padding: 16px 20px;
        }

        .bb-title-input::placeholder {
            font-weight: 400;
            font-size: 16px;
            color: #9AA3B2;
            letter-spacing: 0;
        }

        .bb-title-input::-webkit-input-placeholder {
            font-weight: 400;
            font-size: 16px;
            color: #9AA3B2;
            letter-spacing: 0;
        }

        .bb-title-input::-moz-placeholder {
            font-weight: 400;
            font-size: 16px;
            color: #9AA3B2;
            letter-spacing: 0;
            opacity: 1;
        }

        /* Body textarea */
        .bb-body-input {
            min-height: 320px;
            resize: vertical;
            font-size: 15.5px;
            line-height: 1.65;
            padding: 18px 20px;
            font-family: inherit;
        }

        /* File upload — custom styled drop zone */
        .bb-upload {
            position: relative;
            border: 2px dashed var(--bb-line);
            background: #FAFBFC;
            border-radius: 16px;
            padding: 28px 20px;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.18s ease, background 0.18s ease;
        }

        .bb-upload:hover {
            border-color: var(--bb-blue);
            background: rgba(47,107,255,0.03);
        }

        .bb-upload.has-file {
            border-style: solid;
            border-color: var(--bb-blue);
            background: rgba(47,107,255,0.04);
            padding: 0;
            overflow: hidden;
        }

        .bb-upload input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            width: 100%;
            height: 100%;
            cursor: pointer;
        }

        .bb-upload-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(47,107,255,0.10);
            color: var(--bb-blue);
            display: grid;
            place-items: center;
            margin: 0 auto 12px;
        }

        .bb-upload-title {
            font-size: 14.5px;
            font-weight: 600;
            color: var(--bb-ink);
            margin: 0 0 4px 0;
        }

        .bb-upload-title span {
            color: var(--bb-blue);
            text-decoration: underline;
        }

        .bb-upload-sub {
            font-size: 12.5px;
            color: var(--bb-muted);
            margin: 0;
        }

        /* Preview state */
        .bb-preview {
            display: none;
            position: relative;
        }

        .bb-upload.has-file .bb-upload-default { display: none; }
        .bb-upload.has-file .bb-preview { display: block; }

        .bb-preview img {
            display: block;
            width: 100%;
            max-height: 280px;
            object-fit: cover;
        }

        .bb-preview-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 16px;
            background: #fff;
            border-top: 1px solid var(--bb-line);
            font-size: 13px;
        }

        .bb-preview-name {
            color: var(--bb-ink);
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .bb-preview-remove {
            position: relative;
            z-index: 2;
            border: none;
            background: #FEF2F2;
            color: #991B1B;
            font-family: inherit;
            font-size: 12.5px;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 8px;
            cursor: pointer;
            flex-shrink: 0;
        }

        .bb-preview-remove:hover { background: #FEE2E2; }

        /* Action row */
        .bb-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 28px;
            padding-top: 24px;
            border-top: 1px solid var(--bb-line);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: inherit;
            font-size: 15px;
            font-weight: 600;
            padding: 13px 22px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            transition: transform 0.05s ease, background 0.18s ease, box-shadow 0.18s ease;
            letter-spacing: -0.005em;
        }

        .btn-secondary {
            background: #fff;
            color: var(--bb-ink);
            border: 1.5px solid var(--bb-line);
            text-decoration: none;
        }

        .btn-secondary:hover { background: #F9FAFB; border-color: #D1D5DB; }

        .btn-primary {
            background: linear-gradient(180deg, #3D77FF 0%, #2F6BFF 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(47,107,255,0.32), inset 0 1px 0 rgba(255,255,255,0.18);
        }

        .btn-primary:hover {
            background: linear-gradient(180deg, #2F6BFF 0%, #1E54E0 100%);
            box-shadow: 0 10px 26px rgba(47,107,255,0.38), inset 0 1px 0 rgba(255,255,255,0.18);
        }

        .btn-primary:active { transform: translateY(1px); }

        /* Mobile */
        @media (max-width: 720px) {
            .bb-page { padding: 16px 14px 48px; }
            .bb-page-head { padding: 26px 24px; border-radius: 20px; }
            .bb-page-head h1 { font-size: 26px; }
            .bb-page-head p { font-size: 14px; }
            .bb-card { padding: 24px 20px; border-radius: 20px; }
            .bb-title-input { font-size: 19px; padding: 14px 16px; }
            .bb-title-input::placeholder { font-size: 15px; }
            .bb-body-input { min-height: 240px; padding: 16px; }
            .bb-actions { flex-direction: column-reverse; }
            .bb-actions .btn { width: 100%; }
        }
    </style>
</head>
<body>

    <%- include('./partials/nav') %>

    <div class="bb-page">

        <!-- HEADER STRIP -->
        <header class="bb-page-head">
            <span class="bb-eyebrow">New Post</span>
            <h1>Write something worth reading.</h1>
            <p>Share your thoughts, tutorials, or stories with the ByteBlog community. A great post starts with a clear title and a striking cover.</p>
        </header>

        <!-- FORM CARD -->
        <div class="bb-card">

            <% if (locals.message) { %>
                <div class="bb-alert" role="alert">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <p><%= locals.message %></p>
                </div>
            <% } %>

            <form action="/blog/addBlog" method="post" enctype="multipart/form-data">

                <!-- Cover image -->
                <div class="bb-field">
                    <label class="form-label" for="coverImage">
                        Cover image <span class="form-hint">— recommended 1200×630px</span>
                    </label>
                    <label class="bb-upload" id="uploadBox">
                        <input type="file" name="coverImage" id="coverImage" accept="image/*">

                        <div class="bb-upload-default">
                            <div class="bb-upload-icon">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                    <polyline points="21 15 16 10 5 21"></polyline>
                                </svg>
                            </div>
                            <p class="bb-upload-title"><span>Click to upload</span> or drag &amp; drop</p>
                            <p class="bb-upload-sub">PNG, JPG or WebP — up to 5 MB</p>
                        </div>

                        <div class="bb-preview">
                            <img id="previewImg" alt="Cover preview">
                            <div class="bb-preview-meta">
                                <span class="bb-preview-name" id="previewName">image.jpg</span>
                                <button type="button" class="bb-preview-remove" id="removeBtn">Remove</button>
                            </div>
                        </div>
                    </label>
                </div>

                <!-- Title -->
                <div class="bb-field">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" id="title" name="title" class="form-control bb-title-input" placeholder="An attention-grabbing headline..." required>
                </div>

                <!-- Body -->
                <div class="bb-field">
                    <label for="body" class="form-label">Body</label>
                    <textarea name="body" id="body" class="form-control bb-body-input" placeholder="Tell your story... You can write multiple paragraphs, share insights, or walk through an idea step by step." required></textarea>
                </div>

                <!-- Actions -->
                <div class="bb-actions">
                    <a href="/" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 2 11 13"></path>
                            <path d="M22 2 15 22 11 13 2 9 22 2z"></path>
                        </svg>
                        Publish post
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        // Cover image preview
        (function () {
            const input  = document.getElementById('coverImage');
            const box    = document.getElementById('uploadBox');
            const img    = document.getElementById('previewImg');
            const name   = document.getElementById('previewName');
            const remove = document.getElementById('removeBtn');

            input.addEventListener('change', function () {
                const file = input.files && input.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    name.textContent = file.name;
                    box.classList.add('has-file');
                };
                reader.readAsDataURL(file);
            });

            remove.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                input.value = '';
                box.classList.remove('has-file');
                img.src = '';
            });
        })();
    </script>

    <%- include('./partials/script') %>
</body>
</html>