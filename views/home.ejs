<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>Home</title>
</head>

<body>
    <%- include('./partials/nav') %>
        <p>Welcome to ByteBlog</p>

        <% if (locals.blog && locals.user) { %>
            <% locals.blog.forEach(blog => { %>
                <div class="card" style="width: 18rem;">
                <img src="<%= blog.coverImageUrl %>" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title"><%= blog.title %></h5>
                    <a href="/blog/showBlog/<%= blog._id %>" class="/yet to be inserted">Read</a>
                </div>
            </div>
            <% }) %>

            <% } %>
                <%- include('./partials/script') %>
</body>

</html>