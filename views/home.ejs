<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Home · ByteBlog</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">

    <style>
        :root {
            --bb-blue: #2F6BFF;
            --bb-blue-dark: #1E54E0;
            --bb-blue-light: #4F86FF;
            --bb-ink: #0F172A;
            --bb-ink-soft: #1F2937;
            --bb-muted: #64748B;
            --bb-line: #E5E7EB;
            --bb-bg: #F4F5F7;
            --bb-card: #FFFFFF;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            background: var(--bb-bg);
            color: var(--bb-ink);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Page wrapper */
        .bb-page {
            max-width: 1200px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        /* HERO STRIP */
        .bb-hero {
            position: relative;
            background:
                radial-gradient(120% 80% at 0% 0%, rgba(255,255,255,0.12), transparent 60%),
                radial-gradient(80% 60% at 100% 100%, rgba(255,255,255,0.08), transparent 55%),
                linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
            color: #fff;
            padding: 44px 48px;
            border-radius: 28px;
            overflow: hidden;
            margin-bottom: 36px;
            box-shadow: 0 20px 50px rgba(30, 84, 224, 0.22);
        }

        .bb-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.10) 1px, transparent 1px);
            background-size: 24px 24px;
            opacity: 0.4;
            pointer-events: none;
        }

        .bb-hero::after {
            content: "";
            position: absolute;
            width: 480px;
            height: 480px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
            bottom: -220px;
            right: -160px;
            pointer-events: none;
        }

        .bb-hero-inner {
            position: relative;
            z-index: 1;
            max-width: 640px;
        }

        .bb-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(255,255,255,0.14);
            border: 1px solid rgba(255,255,255,0.24);
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            margin-bottom: 18px;
        }

        .bb-eyebrow-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #4ADE80;
            box-shadow: 0 0 8px #4ADE80;
        }

        .bb-hero h1 {
            font-size: 42px;
            line-height: 1.1;
            font-weight: 700;
            margin: 0 0 14px 0;
            letter-spacing: -0.025em;
        }

        .bb-hero p {
            font-size: 16px;
            line-height: 1.6;
            color: rgba(255,255,255,0.88);
            margin: 0 0 24px 0;
        }

        .bb-hero-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .bb-hero-cta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 22px;
            background: #fff;
            color: var(--bb-blue);
            border-radius: 12px;
            text-decoration: none;
            font-size: 14.5px;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
            transition: transform 0.05s ease, box-shadow 0.18s ease;
        }
        .bb-hero-cta:hover { box-shadow: 0 10px 26px rgba(0, 0, 0, 0.2); }
        .bb-hero-cta:active { transform: translateY(1px); }
        .bb-hero-cta svg { width: 16px; height: 16px; }

        .bb-hero-ghost {
            display: inline-flex;
            align-items: center;
            padding: 12px 22px;
            background: rgba(255, 255, 255, 0.12);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 12px;
            text-decoration: none;
            font-size: 14.5px;
            font-weight: 600;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            transition: background 0.18s ease;
        }
        .bb-hero-ghost:hover { background: rgba(255, 255, 255, 0.2); }

        /* SECTION HEADER */
        .bb-section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
            gap: 16px;
        }

        .bb-section-title {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--bb-ink);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .bb-section-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
            height: 24px;
            padding: 0 8px;
            background: rgba(47, 107, 255, 0.10);
            color: var(--bb-blue);
            border-radius: 999px;
            font-size: 12.5px;
            font-weight: 600;
        }

        /* BLOG GRID */
        .bb-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 22px;
        }

        @media (max-width: 980px) {
            .bb-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 620px) {
            .bb-grid { grid-template-columns: 1fr; gap: 16px; }
        }

        /* BLOG CARD */
        .bb-card {
            display: flex;
            flex-direction: column;
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.06);
            border-radius: 18px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04), 0 4px 12px rgba(15, 23, 42, 0.04);
        }
        .bb-card:hover {
            transform: translateY(-3px);
            border-color: rgba(15, 23, 42, 0.10);
            box-shadow: 0 14px 32px rgba(15, 23, 42, 0.10);
        }

        /* Cover — uses 'cover' fit for clean thumbnail look */
        .bb-card-cover {
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 10;
            background:
                radial-gradient(circle at 50% 50%, #FAFBFC 0%, #ECEEF1 100%);
            overflow: hidden;
            border-bottom: 1px solid rgba(15, 23, 42, 0.05);
        }
        .bb-card-cover img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }
        .bb-card:hover .bb-card-cover img { transform: scale(1.04); }

        /* Placeholder when no cover image */
        .bb-card-placeholder {
            position: absolute;
            inset: 0;
            display: grid;
            place-items: center;
            color: var(--bb-muted);
        }
        .bb-card-placeholder svg { width: 36px; height: 36px; opacity: 0.5; }

        .bb-card-body {
            padding: 18px 20px 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            flex: 1;
        }

        .bb-card-title {
            font-size: 17px;
            font-weight: 700;
            letter-spacing: -0.015em;
            line-height: 1.35;
            color: var(--bb-ink);
            margin: 0;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .bb-card-foot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: auto;
            padding-top: 4px;
        }

        .bb-card-read {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            color: var(--bb-blue);
            font-size: 13.5px;
            font-weight: 600;
        }
        .bb-card-read svg { width: 14px; height: 14px; transition: transform 0.18s ease; }
        .bb-card:hover .bb-card-read svg { transform: translateX(2px); }

        .bb-card-tag {
            font-size: 11px;
            color: var(--bb-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 500;
        }

        /* EMPTY / GUEST STATES */
        .bb-empty {
            background: #fff;
            border: 1px dashed var(--bb-line);
            border-radius: 20px;
            padding: 48px 24px;
            text-align: center;
            color: var(--bb-muted);
        }

        .bb-empty-icon {
            width: 56px;
            height: 56px;
            margin: 0 auto 16px;
            border-radius: 14px;
            background: rgba(47, 107, 255, 0.08);
            color: var(--bb-blue);
            display: grid;
            place-items: center;
        }

        .bb-empty h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--bb-ink);
            margin: 0 0 6px 0;
        }

        .bb-empty p {
            font-size: 14.5px;
            margin: 0 0 20px 0;
            line-height: 1.5;
        }

        .bb-empty-cta {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 11px 20px;
            background: linear-gradient(180deg, #3D77FF 0%, #2F6BFF 100%);
            color: #fff;
            text-decoration: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(47,107,255,0.32), inset 0 1px 0 rgba(255,255,255,0.18);
            transition: box-shadow 0.18s ease, transform 0.05s ease;
        }
        .bb-empty-cta:hover {
            background: linear-gradient(180deg, #2F6BFF 0%, #1E54E0 100%);
            box-shadow: 0 10px 26px rgba(47,107,255,0.38), inset 0 1px 0 rgba(255,255,255,0.18);
        }
        .bb-empty-cta:active { transform: translateY(1px); }
        .bb-empty-cta svg { width: 14px; height: 14px; }

        /* Mobile */
        @media (max-width: 720px) {
            .bb-page { padding: 20px 16px 56px; }
            .bb-hero { padding: 32px 26px; border-radius: 22px; margin-bottom: 28px; }
            .bb-hero h1 { font-size: 30px; }
            .bb-hero p { font-size: 14.5px; }
            .bb-hero-cta, .bb-hero-ghost { padding: 11px 18px; font-size: 14px; }
            .bb-section-title { font-size: 20px; }

            /* Mobile card tweaks — keep them feeling like cards, not full sections */
            .bb-card {
                border-radius: 16px;
                box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 6px 16px rgba(15, 23, 42, 0.06);
            }
            .bb-card-cover {
                aspect-ratio: 16 / 9;  /* Slightly wider/shorter on mobile */
            }
            .bb-card-body {
                padding: 14px 16px 16px;
                gap: 10px;
            }
            .bb-card-title { font-size: 16px; }
            .bb-card-tag { font-size: 10.5px; }
            .bb-card-read { font-size: 13px; }
        }
    </style>
</head>
<body>

    <%- include('./partials/nav') %>

    <div class="bb-page">

        <!-- HERO -->
        <section class="bb-hero">
            <div class="bb-hero-inner">
                <span class="bb-eyebrow">
                    <span class="bb-eyebrow-dot"></span>
                    <% if (locals.user) { %>
                        Welcome back<%= locals.user.fullname ? ', ' + locals.user.fullname.split(' ')[0] : '' %>
                    <% } else { %>
                        Welcome to ByteBlog
                    <% } %>
                </span>
                <h1>Stories, ideas and bytes — all in one place.</h1>
                <p>Discover thoughtful writing from developers, makers, and dreamers. Read what inspires you and share your own ideas with a community of curious minds.</p>

                <div class="bb-hero-actions">
                    <% if (locals.user) { %>
                        <a href="/blog/addBlog" class="bb-hero-cta">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9"></path>
                                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                            </svg>
                            Write a post
                        </a>
                        <a href="#latest" class="bb-hero-ghost">Browse posts</a>
                    <% } else { %>
                        <a href="/user/signup" class="bb-hero-cta">
                            Get started
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </a>
                        <a href="/user/signin" class="bb-hero-ghost">Sign in</a>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- LATEST POSTS -->
        <section id="latest">

            <div class="bb-section-head">
                <h2 class="bb-section-title">
                    Latest posts
                    <% if (locals.blog && locals.blog.length > 0) { %>
                        <span class="bb-section-count"><%= locals.blog.length %></span>
                    <% } %>
                </h2>
            </div>

            <% if (locals.blog && locals.blog.length > 0) { %>

                <div class="bb-grid">
                    <% locals.blog.forEach(blog => { %>
                        <a class="bb-card" href="/blog/showBlog/<%= blog._id %>">
                            <div class="bb-card-cover">
                                <% if (blog.coverImageUrl) { %>
                                    <img src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>" loading="lazy">
                                <% } else { %>
                                    <div class="bb-card-placeholder">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                            <polyline points="21 15 16 10 5 21"></polyline>
                                        </svg>
                                    </div>
                                <% } %>
                            </div>
                            <div class="bb-card-body">
                                <h3 class="bb-card-title"><%= blog.title %></h3>
                                <div class="bb-card-foot">
                                    <span class="bb-card-tag">Article</span>
                                    <span class="bb-card-read">
                                        Read more
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="5" y1="12" x2="19" y2="12"></line>
                                            <polyline points="12 5 19 12 12 19"></polyline>
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>

            <% } else if (locals.user) { %>

                <!-- Logged in but no posts yet -->
                <div class="bb-empty">
                    <div class="bb-empty-icon">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 20h9"></path>
                            <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                        </svg>
                    </div>
                    <h3>No posts yet</h3>
                    <p>Be the first to share something with the community.<br>Your story could be exactly what someone needs to read today.</p>
                    <a href="/blog/addBlog" class="bb-empty-cta">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 20h9"></path>
                            <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                        </svg>
                        Write the first post
                    </a>
                </div>

            <% } else { %>

                <!-- Guest user -->
                <div class="bb-empty">
                    <div class="bb-empty-icon">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    <h3>Sign in to see the feed</h3>
                    <p>Create a free account to read posts, follow writers,<br>and share your own ideas with the ByteBlog community.</p>
                    <a href="/user/signup" class="bb-empty-cta">
                        Create your account
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>

            <% } %>

        </section>
    </div>

    <%- include('./partials/script') %>
</body>
</html>