<style>
    /* ===== ByteBlog Navbar ===== */
    .bb-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(244, 245, 247, 0.85);
        backdrop-filter: saturate(180%) blur(14px);
        -webkit-backdrop-filter: saturate(180%) blur(14px);
        border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .bb-nav-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    /* Brand — matches signin/signup pill style, inverted for light bg */
    .bb-nav-brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-weight: 700;
        font-size: 17px;
        color: #0F172A;
        text-decoration: none;
        letter-spacing: -0.01em;
        padding: 6px 16px 6px 6px;
        background: #fff;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 999px;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .bb-nav-brand:hover {
        border-color: rgba(15, 23, 42, 0.14);
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
    }

    .bb-nav-brand-mark {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
        color: #fff;
        display: grid;
        place-items: center;
        font-weight: 800;
        font-size: 14px;
        box-shadow: 0 4px 10px rgba(47, 107, 255, 0.30);
        flex-shrink: 0;
    }

    /* Links */
    .bb-nav-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .bb-nav-link {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 14px;
        font-size: 14px;
        font-weight: 500;
        color: #475569;
        text-decoration: none;
        border-radius: 10px;
        transition: background 0.18s ease, color 0.18s ease;
        cursor: pointer;
        background: transparent;
        border: none;
        font-family: inherit;
    }

    .bb-nav-link:hover {
        background: rgba(15, 23, 42, 0.05);
        color: #0F172A;
    }

    .bb-nav-link.active {
        color: #2F6BFF;
        background: rgba(47, 107, 255, 0.10);
        font-weight: 600;
    }

    .bb-nav-link svg { width: 16px; height: 16px; }

    /* Right cluster */
    .bb-nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Primary CTA in nav */
    .bb-nav-cta {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 16px;
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        text-decoration: none;
        border-radius: 10px;
        background: linear-gradient(180deg, #3D77FF 0%, #2F6BFF 100%);
        box-shadow: 0 6px 14px rgba(47, 107, 255, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.18);
        transition: box-shadow 0.18s ease, transform 0.05s ease;
        border: none;
        cursor: pointer;
        font-family: inherit;
    }

    .bb-nav-cta:hover {
        background: linear-gradient(180deg, #2F6BFF 0%, #1E54E0 100%);
        box-shadow: 0 8px 18px rgba(47, 107, 255, 0.36), inset 0 1px 0 rgba(255, 255, 255, 0.18);
    }
    .bb-nav-cta:active { transform: translateY(1px); }
    .bb-nav-cta svg { width: 15px; height: 15px; }

    /* Secondary outline button */
    .bb-nav-ghost {
        display: inline-flex;
        align-items: center;
        padding: 9px 16px;
        font-size: 14px;
        font-weight: 600;
        color: #0F172A;
        text-decoration: none;
        border-radius: 10px;
        border: 1.5px solid #E5E7EB;
        background: #fff;
        transition: border-color 0.18s ease, background 0.18s ease;
    }
    .bb-nav-ghost:hover { border-color: #D1D5DB; background: #F9FAFB; }

    /* Dropdown wrapper */
    .bb-dd { position: relative; }

    .bb-dd-trigger {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 14px 5px 5px;
        font-size: 14px;
        font-weight: 500;
        color: #0F172A;
        background: #fff;
        border: 1.5px solid #E5E7EB;
        border-radius: 999px;
        cursor: pointer;
        font-family: inherit;
        transition: border-color 0.18s ease, background 0.18s ease;
    }
    .bb-dd-trigger:hover { border-color: #D1D5DB; background: #F9FAFB; }

    .bb-dd-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
        color: #fff;
        display: grid;
        place-items: center;
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        flex-shrink: 0;
    }

    .bb-dd-name {
        max-width: 120px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .bb-dd-chev {
        width: 14px;
        height: 14px;
        color: #64748B;
        transition: transform 0.18s ease;
    }
    .bb-dd.open .bb-dd-chev { transform: rotate(180deg); }

    .bb-dd-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 200px;
        background: #fff;
        border: 1px solid rgba(15, 23, 42, 0.06);
        border-radius: 14px;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12), 0 2px 6px rgba(15, 23, 42, 0.04);
        padding: 6px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
        transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
    }
    .bb-dd.open .bb-dd-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .bb-dd-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        font-size: 14px;
        color: #0F172A;
        text-decoration: none;
        border-radius: 9px;
        transition: background 0.15s ease;
    }
    .bb-dd-item:hover { background: #F4F5F7; }
    .bb-dd-item svg { width: 15px; height: 15px; color: #64748B; }
    .bb-dd-item.danger { color: #DC2626; }
    .bb-dd-item.danger:hover { background: #FEF2F2; }
    .bb-dd-item.danger svg { color: #DC2626; }

    .bb-dd-divider {
        height: 1px;
        background: #F1F2F4;
        margin: 4px 0;
    }

    /* Mobile toggler */
    .bb-nav-toggle {
        display: none;
        background: #fff;
        border: 1.5px solid #E5E7EB;
        border-radius: 10px;
        padding: 8px;
        cursor: pointer;
        color: #0F172A;
    }
    .bb-nav-toggle svg { width: 20px; height: 20px; display: block; }

    /* Mobile */
    @media (max-width: 820px) {
        .bb-nav-inner { padding: 12px 16px; }

        .bb-nav-brand {
            font-size: 16px;
            padding: 5px 14px 5px 5px;
            gap: 10px;
        }
        .bb-nav-brand-mark { width: 28px; height: 28px; font-size: 13px; }

        .bb-nav-toggle { display: inline-flex; }

        .bb-nav-collapse {
            position: absolute;
            top: 100%;
            left: 12px;
            right: 12px;
            margin-top: 10px;
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.06);
            border-radius: 16px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.10);
            padding: 10px;
            display: none;
            flex-direction: column;
            gap: 4px;
        }
        .bb-nav-collapse.open { display: flex; }

        .bb-nav-links {
            flex-direction: column;
            align-items: stretch;
            gap: 2px;
        }

        .bb-nav-link {
            justify-content: flex-start;
            padding: 11px 14px;
            font-size: 14.5px;
        }

        .bb-nav-right {
            flex-direction: column;
            align-items: stretch;
            gap: 6px;
            margin-top: 6px;
            padding-top: 10px;
            border-top: 1px solid #F1F2F4;
        }

        .bb-nav-cta,
        .bb-nav-ghost {
            justify-content: center;
            width: 100%;
        }

        .bb-dd { width: 100%; }
        .bb-dd-trigger {
            width: 100%;
            justify-content: flex-start;
            border-radius: 10px;
        }
        .bb-dd-name { max-width: none; flex: 1; }

        .bb-dd-menu {
            position: static;
            opacity: 1;
            visibility: visible;
            transform: none;
            display: none;
            box-shadow: none;
            border: none;
            background: transparent;
            padding: 4px 0 0 0;
            margin-top: 4px;
        }
        .bb-dd.open .bb-dd-menu { display: block; }
    }
</style>

<nav class="bb-nav">
    <div class="bb-nav-inner">

        <!-- BRAND -->
        <a class="bb-nav-brand" href="/">
            <span class="bb-nav-brand-mark">B</span>
            <span>ByteBlog</span>
        </a>

        <!-- MOBILE TOGGLE -->
        <button class="bb-nav-toggle" type="button" id="bbNavToggle" aria-label="Toggle navigation" aria-expanded="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>

        <!-- COLLAPSE -->
        <div class="bb-nav-collapse" id="bbNavCollapse">

            <!-- LINKS -->
            <ul class="bb-nav-links">
                <li>
                    <a class="bb-nav-link active" aria-current="page" href="/">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                            <polyline points="9 22 9 12 15 12 15 22"></polyline>
                        </svg>
                        Home
                    </a>
                </li>

                <% if (locals.user !== undefined) { %>
                    <li>
                        <a class="bb-nav-link" href="/blog/addBlog">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 20h9"></path>
                                <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                            </svg>
                            Write
                        </a>
                    </li>
                <% } %>
            </ul>

            <!-- RIGHT CLUSTER -->
            <div class="bb-nav-right">

                <% if (locals.user !== undefined) { %>
                    <!-- Logged in: avatar dropdown -->
                    <div class="bb-dd" id="bbUserDd">
                        <button class="bb-dd-trigger" type="button" aria-haspopup="true" aria-expanded="false">
                            <span class="bb-dd-avatar"><%= locals.user.name.charAt(0) %></span>
                            <span class="bb-dd-name"><%= locals.user.name %></span>
                            <svg class="bb-dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="bb-dd-menu" role="menu">
                            <a class="bb-dd-item" href="/user/profile">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                My profile
                            </a>
                            <a class="bb-dd-item" href="/blog/addBlog">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 20h9"></path>
                                    <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4z"></path>
                                </svg>
                                New post
                            </a>
                            <div class="bb-dd-divider"></div>
                            <a class="bb-dd-item danger" href="/user/logout">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                    <polyline points="16 17 21 12 16 7"></polyline>
                                    <line x1="21" y1="12" x2="9" y2="12"></line>
                                </svg>
                                Log out
                            </a>
                        </div>
                    </div>
                <% } %>

                <% if (locals.user === undefined) { %>
                    <!-- Logged out: sign-in + CTA -->
                    <a class="bb-nav-ghost" href="/user/signin">Sign in</a>
                    <a class="bb-nav-cta" href="/user/signup">
                        Get started
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                <% } %>

            </div>
        </div>
    </div>
</nav>

<script>
    (function () {
        // Mobile collapse toggle
        const toggle   = document.getElementById('bbNavToggle');
        const collapse = document.getElementById('bbNavCollapse');
        if (toggle && collapse) {
            toggle.addEventListener('click', function () {
                const isOpen = collapse.classList.toggle('open');
                toggle.setAttribute('aria-expanded', isOpen);
            });
        }

        // User dropdown toggle
        const dd = document.getElementById('bbUserDd');
        if (dd) {
            const trigger = dd.querySelector('.bb-dd-trigger');
            trigger.addEventListener('click', function (e) {
                e.stopPropagation();
                const isOpen = dd.classList.toggle('open');
                trigger.setAttribute('aria-expanded', isOpen);
            });
            document.addEventListener('click', function (e) {
                if (!dd.contains(e.target)) {
                    dd.classList.remove('open');
                    trigger.setAttribute('aria-expanded', 'false');
                }
            });
        }
    })();
</script>