<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Change Profile Image · ByteBlog</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='16' fill='%232F6BFF'/><text x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica,Arial,sans-serif' font-weight='800' font-size='38' fill='white'>B</text></svg>">

    <style>
        :root {
            --bb-blue: #2F6BFF;
            --bb-blue-dark: #1E54E0;
            --bb-blue-light: #4F86FF;
            --bb-ink: #0F172A;
            --bb-ink-soft: #1F2937;
            --bb-muted: #64748B;
            --bb-line: #E5E7EB;
            --bb-bg: #F4F5F7;
            --bb-card: #FFFFFF;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            background: var(--bb-bg);
            color: var(--bb-ink);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .bb-page {
            max-width: 560px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        /* Back link */
        .bb-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--bb-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 28px;
            transition: color 0.18s ease;
        }
        .bb-back:hover { color: var(--bb-ink); }
        .bb-back svg { width: 16px; height: 16px; }

        /* Page header strip */
        .bb-page-head {
            position: relative;
            background:
                radial-gradient(120% 80% at 0% 0%, rgba(255,255,255,0.12), transparent 60%),
                radial-gradient(80% 60% at 100% 100%, rgba(255,255,255,0.08), transparent 55%),
                linear-gradient(160deg, #1E54E0 0%, #2F6BFF 55%, #4F86FF 100%);
            color: #fff;
            padding: 32px 36px;
            border-radius: 22px;
            overflow: hidden;
            margin-bottom: 24px;
            box-shadow: 0 16px 40px rgba(30, 84, 224, 0.20);
        }

        .bb-page-head::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.10) 1px, transparent 1px);
            background-size: 22px 22px;
            opacity: 0.4;
            pointer-events: none;
        }

        .bb-page-head::after {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, transparent 70%);
            bottom: -140px;
            right: -100px;
            pointer-events: none;
        }

        .bb-page-head-inner {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .bb-page-head-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.16);
            border: 1px solid rgba(255, 255, 255, 0.25);
            display: grid;
            place-items: center;
            flex-shrink: 0;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        .bb-page-head-icon svg { width: 24px; height: 24px; }

        .bb-page-head h1 {
            font-size: 26px;
            font-weight: 700;
            margin: 0 0 4px 0;
            letter-spacing: -0.02em;
        }

        .bb-page-head p {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.82);
            margin: 0;
            line-height: 1.45;
        }

        /* Form card */
        .bb-card {
            background: var(--bb-card);
            border-radius: 22px;
            padding: 32px 32px;
            box-shadow:
                0 1px 2px rgba(15, 23, 42, 0.04),
                0 8px 24px rgba(15, 23, 42, 0.06);
            border: 1px solid rgba(15, 23, 42, 0.04);
        }

        /* Upload drop zone */
        .bb-upload {
            position: relative;
            border: 2px dashed var(--bb-line);
            background: #FAFBFC;
            border-radius: 16px;
            padding: 36px 20px;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.18s ease, background 0.18s ease;
            margin-bottom: 22px;
        }

        .bb-upload:hover {
            border-color: var(--bb-blue);
            background: rgba(47, 107, 255, 0.03);
        }

        .bb-upload.has-file {
            border-style: solid;
            border-color: var(--bb-blue);
            background: rgba(47, 107, 255, 0.04);
            padding: 0;
            overflow: hidden;
        }

        .bb-upload input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            width: 100%;
            height: 100%;
            cursor: pointer;
        }

        /* Default upload state */
        .bb-upload-default { padding: 8px 0; }

        .bb-upload-icon {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: rgba(47, 107, 255, 0.10);
            color: var(--bb-blue);
            display: grid;
            place-items: center;
            margin: 0 auto 14px;
        }
        .bb-upload-icon svg { width: 26px; height: 26px; }

        .bb-upload-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--bb-ink);
            margin: 0 0 5px 0;
        }

        .bb-upload-title span {
            color: var(--bb-blue);
            text-decoration: underline;
        }

        .bb-upload-sub {
            font-size: 12.5px;
            color: var(--bb-muted);
            margin: 0;
        }

        /* Preview state */
        .bb-preview { display: none; }
        .bb-upload.has-file .bb-upload-default { display: none; }
        .bb-upload.has-file .bb-preview { display: block; }

        .bb-preview-inner {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 20px;
        }

        .bb-preview-img {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(47, 107, 255, 0.25);
            flex-shrink: 0;
        }

        .bb-preview-info {
            flex: 1;
            min-width: 0;
        }

        .bb-preview-label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.10em;
            color: var(--bb-blue);
            margin-bottom: 4px;
        }

        .bb-preview-name {
            font-size: 14px;
            font-weight: 500;
            color: var(--bb-ink);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .bb-preview-remove {
            position: relative;
            z-index: 2;
            border: none;
            background: #FEF2F2;
            color: #991B1B;
            font-family: inherit;
            font-size: 12.5px;
            font-weight: 600;
            padding: 7px 13px;
            border-radius: 8px;
            cursor: pointer;
            flex-shrink: 0;
            transition: background 0.18s ease;
        }
        .bb-preview-remove:hover { background: #FEE2E2; }

        /* Tips */
        .bb-tips {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 24px;
        }

        .bb-tip {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: var(--bb-muted);
        }

        .bb-tip-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--bb-blue);
            opacity: 0.45;
            flex-shrink: 0;
        }

        /* Actions */
        .bb-actions {
            display: flex;
            gap: 12px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: inherit;
            font-size: 15px;
            font-weight: 600;
            padding: 14px 22px;
            border-radius: 13px;
            border: none;
            cursor: pointer;
            transition: transform 0.05s ease, background 0.18s ease, box-shadow 0.18s ease;
            letter-spacing: -0.005em;
            text-decoration: none;
        }

        .btn-primary {
            flex: 1;
            background: linear-gradient(180deg, #3D77FF 0%, #2F6BFF 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(47,107,255,0.32), inset 0 1px 0 rgba(255,255,255,0.18);
        }
        .btn-primary:hover {
            background: linear-gradient(180deg, #2F6BFF 0%, #1E54E0 100%);
            box-shadow: 0 10px 26px rgba(47,107,255,0.38), inset 0 1px 0 rgba(255,255,255,0.18);
        }
        .btn-primary:active { transform: translateY(1px); }
        .btn-primary svg { width: 16px; height: 16px; }

        .btn-secondary {
            background: #fff;
            color: var(--bb-ink);
            border: 1.5px solid var(--bb-line);
        }
        .btn-secondary:hover { background: #F9FAFB; border-color: #D1D5DB; }

        /* Mobile */
        @media (max-width: 600px) {
            .bb-page { padding: 20px 16px 56px; }
            .bb-page-head { padding: 24px 22px; border-radius: 18px; }
            .bb-page-head h1 { font-size: 22px; }
            .bb-card { padding: 24px 20px; border-radius: 18px; }
            .bb-actions { flex-direction: column; }
            .bb-btn-secondary { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

    <%- include('./partials/nav') %>

    <div class="bb-page">

        <!-- Back link -->
        <a href="/user/profile" class="bb-back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to profile
        </a>

        <!-- Header strip -->
        <div class="bb-page-head">
            <div class="bb-page-head-inner">
                <div class="bb-page-head-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                        <circle cx="12" cy="13" r="4"/>
                    </svg>
                </div>
                <div>
                    <h1>Update Profile Image</h1>
                    <p>Choose a new photo to represent you across ByteBlog.</p>
                </div>
            </div>
        </div>

        <!-- Form card -->
        <div class="bb-card">

            <form action="/user/changeProfileImage" method="post" enctype="multipart/form-data">

                <!-- Upload zone -->
                <label class="bb-upload" id="uploadBox">
                    <input type="file" name="profileImage" id="profileImage" accept="image/*">

                    <div class="bb-upload-default">
                        <div class="bb-upload-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                                <circle cx="12" cy="13" r="4"/>
                            </svg>
                        </div>
                        <p class="bb-upload-title"><span>Click to upload</span> or drag &amp; drop</p>
                        <p class="bb-upload-sub">PNG, JPG or WebP — square images work best</p>
                    </div>

                    <div class="bb-preview">
                        <div class="bb-preview-inner">
                            <img id="previewImg" class="bb-preview-img" src="" alt="Preview">
                            <div class="bb-preview-info">
                                <div class="bb-preview-label">New photo selected</div>
                                <div class="bb-preview-name" id="previewName">image.jpg</div>
                            </div>
                            <button type="button" class="bb-preview-remove" id="removeBtn">Remove</button>
                        </div>
                    </div>
                </label>

                <!-- Tips -->
                <div class="bb-tips">
                    <div class="bb-tip">
                        <span class="bb-tip-dot"></span>
                        Use a square image for best results — it will be displayed as a circle.
                    </div>
                    <div class="bb-tip">
                        <span class="bb-tip-dot"></span>
                        Recommended size: 400×400px or larger.
                    </div>
                    <div class="bb-tip">
                        <span class="bb-tip-dot"></span>
                        Accepted formats: PNG, JPG, WebP.
                    </div>
                </div>

                <!-- Actions -->
                <div class="bb-actions">
                    <a href="/user/profile" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                            <circle cx="12" cy="13" r="4"/>
                        </svg>
                        Update Profile Image
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        (function () {
            const input  = document.getElementById('profileImage');
            const box    = document.getElementById('uploadBox');
            const img    = document.getElementById('previewImg');
            const name   = document.getElementById('previewName');
            const remove = document.getElementById('removeBtn');

            input.addEventListener('change', function () {
                const file = input.files && input.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    name.textContent = file.name;
                    box.classList.add('has-file');
                };
                reader.readAsDataURL(file);
            });

            remove.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                input.value = '';
                box.classList.remove('has-file');
                img.src = '';
            });
        })();
    </script>

    <%- include('./partials/script') %>
</body>
</html>